@{
    ViewData["Title"] = "Student Records";
}
@model List<studentAPP.Models.Student>
    
<h4>REGISTER STUDENT</h4>

<form asp-controller="Student" asp-action="registerStudent" method="post" class="w-50 mx-auto mb-10">
    <div class="form-group">
        <label class="control-label">Name</label>
        <input name="name" class="form-control" required />
    </div>
    <div class="form-group">
        <label class="control-label"> Email:</label>
        <input name="email" class="form-control" required />
    </div>
    <div class="form-group">
        <label class="control-label"> Phone No: </label>
        <input type="phone" name="phone" class="form-control" required />
    </div>
    <div class="form-group mt-3 mx-auto">
        <input type="submit" value="Create" class="btn btn-success w-100" />
    </div>
</form>

<h6>Student List</h6>
<p> Total : @(Model?.Count ?? 0)</p>

@if (Model.Count == 0)
{
    <p>No students Record Found!!</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in Model)
            {

                <tr>
                    <td>@student.Id</td>
                    <td>@student.Name</td>
                    <td>@student.Email</td>
                    <td>@student.Phone</td>
                </tr>
            }
        </tbody>
    </table>
}


