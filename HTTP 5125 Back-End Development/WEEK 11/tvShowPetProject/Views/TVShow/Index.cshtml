@model List<tvShowPetProject.Models.Shows>
@{
    ViewData["Title"] = "TV Shows";
}
<h1>@ViewData["Title"]</h1>

<p>Use this page to detail your site's privacy policy.</p>
<div class="text-center">
    <h1 class="display-4">TV Shows</h1>
    <p>Here is a list of TV shows fetched from the TV Maze API.</p>
</div>
<div class="row">
    @foreach (var show in Model)
    {
        <div class="col-md-3 my-5">
            <div class="card rounded-4 shadow" style="width: 18rem;">
                <img src="@show.image?.medium" alt="@show.name" class="card-img-top" />
                <div class="card-body">
                    <h5 class="card-title">@show.name</h5>
                    <p class="card-text">Some quick example text to build on the card title and make up the bulk of the
                        card’s content.</p>
                        @foreach (var genre in show.genres.Take(2))
                        {
                            <span
                                class="badge text-bg-@(genre == "Action" ? "primary" : genre == "Drama" ? "danger" : "secondary") me-1">
                                @genre
                            </span>

                        }
                        @* <a href="@show.url" class="btn btn-primary" target="_blank">Go somewhere</a> *@
                    </div>
                </div>
            </div>
        }

    </div>
    <table class="table">
        <thead>
            <tr>
                <th>S.No</th>
                <th>Name</th>
                <th>Language</th>
                <th>Poster</th>
                <th>Genre</th>
            </tr>
        </thead>
        <tbody>
            @* @{
                var index = 1;
            }
            @foreach (var show in Model)
            {
                <tr>
                    <td>@index</td>
                    <td>@show.name</td>
                    <td>@show.language</td>
                    <td>
                        <img src="@show.image?.medium" alt="@show.name" />
                    </td>
                    <td>@string.Join(", ", show.genres)</td>
                </tr>
                index++;
            } *@
        </tbody>